{
  "uid": "nexus-infrastructure",
  "title": "Nexus — Infrastructure",
  "description": "Kafka consumer lag, PostgreSQL connection pool, Redis memory, and pod-level resource utilisation.",
  "tags": ["nexus", "infrastructure", "kafka", "postgres", "redis"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Kafka",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Consumer Lag — nexus.settlements",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(kafka_consumer_group_lag{topic=\"nexus.settlements\"}) by (consumergroup)",
          "legendFormat": "{{consumergroup}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Consumer Lag — nexus.fraud.alerts",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "sum(kafka_consumer_group_lag{topic=\"nexus.fraud.alerts\"}) by (consumergroup)",
          "legendFormat": "{{consumergroup}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "DLQ Depth (settlements + fraud)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "sparkline",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(kafka_consumer_group_lag{topic=~\".*\\.dlq\"})",
          "legendFormat": "DLQ depth"
        }
      ]
    },
    {
      "id": 5,
      "title": "Kafka Messages Produced (per/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 5, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "msgps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "sum(rate(kafka_producer_record_send_total[1m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "row",
      "title": "PostgreSQL",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Active DB Connections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "active"
        },
        {
          "expr": "pg_stat_activity_count{state=\"idle in transaction\"}",
          "legendFormat": "idle in tx"
        }
      ]
    },
    {
      "id": 8,
      "title": "DB Pool — Checked-out / Available",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "db_pool_checked_out_connections{service=\"settlement-service\"}",
          "legendFormat": "checked-out"
        },
        {
          "expr": "db_pool_available_connections{service=\"settlement-service\"}",
          "legendFormat": "available"
        }
      ]
    },
    {
      "id": 9,
      "title": "Transaction Rate (tps)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_commit{datname=\"nexus_settlement\"}[1m]))",
          "legendFormat": "commits/s"
        },
        {
          "expr": "sum(rate(pg_stat_database_xact_rollback{datname=\"nexus_settlement\"}[1m]))",
          "legendFormat": "rollbacks/s"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Redis",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Redis Memory Used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 805306368 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 12,
      "title": "Redis Hit Rate (%)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 19, "w": 8, "h": 8 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "id": 13,
      "title": "Redis Connected Clients",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "clients"
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Pod Resources",
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 15,
      "title": "CPU Usage by Pod",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 1 } }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"nexus-settlement\",image!=\"\"}[2m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 16,
      "title": "Memory Usage by Pod",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 1 } }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"nexus-settlement\",image!=\"\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}

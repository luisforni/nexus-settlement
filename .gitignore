# ──────────────────────────────────────────────
# Nexus Settlement — .gitignore
# ──────────────────────────────────────────────

# Environment / secrets — NEVER commit real .env
.env
.env.local
.env.*.local
.keys/
*.secret

# Node.js
node_modules/
dist/
build/
.npm
*.tsbuildinfo
coverage/
.nyc_output/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.Python
*.egg-info/
dist/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.log

# ML models (large binaries — store in object storage)
*.pkl
*.joblib
*.h5
*.onnx
models/artifacts/

# Docker
.docker/

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfplan
crash.log

# Kubernetes secrets (never commit raw secret manifests)
infrastructure/k8s/*-secret.yaml

# Test artifacts
junit.xml
test-results/

# Grafana provisioning data
infrastructure/monitoring/grafana/data/

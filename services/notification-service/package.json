{
  "name": "@nexus-settlement/notification-service",
  "version": "1.0.0",
  "description": "Kafka-driven notification service — email (AWS SES), SMS (Twilio), webhook dispatch",
  "engines": { "node": ">=20.0.0" },
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "fmt": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "@aws-sdk/client-ses": "^3.577.0",
    "twilio": "^5.0.4",
    "axios": "^1.7.2",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.6",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "prettier": "^3.2.5"
  }
}

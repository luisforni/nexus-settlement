{
  "name": "@nexus-settlement/notification-service",
  "version": "1.0.0",
  "description": "Kafka-driven notification service — email (AWS SES), SMS (Twilio), webhook dispatch",
  "engines": { "node": ">=20.0.0" },
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "fmt": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "mutate": "stryker run"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@opentelemetry/core": "^1.25.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.52.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "kafkajs": "^2.2.4",
    "@aws-sdk/client-ses": "^3.577.0",
    "twilio": "^5.0.4",
    "axios": "^1.7.2",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.6",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "prettier": "^3.2.5",
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1",
    "@stryker-mutator/core": "^8.2.6",
    "@stryker-mutator/jest-runner": "^8.2.6"
  }
}

<?xml version="1.0" encoding="UTF-8"?>
<!--
  OWASP Dependency Check — false-positive suppressions
  Docs: https://jeremylong.github.io/DependencyCheck/general/suppression.html

  Each <suppress> entry documents WHY a CVE is being suppressed.
  Always include an <notes> element explaining the rationale and a review date.
  Remove entries whose 'until' date has passed.
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!--
    Example suppression template (remove/keep as needed):

    <suppress until="2026-09-01Z">
      <notes>
        CVE-XXXX-XXXXX: Affects feature Y which is not used in this project.
        Reviewed: 2026-03-10. Re-evaluate on the 'until' date.
      </notes>
      <cve>CVE-XXXX-XXXXX</cve>
    </suppress>
  -->

  <!--
    psutil / pyopenssl — scanner incorrectly matches local dev packages
    against server-side CVEs that do not apply to our usage.
  -->
  <!--
  <suppress until="2026-09-10Z">
    <notes>False positive: psutil CVE affects a Windows-only code path.
    Our deployment target is Linux (Alpine). Reviewed 2026-03-10.</notes>
    <packageUrl regex="true">^pkg:pypi/psutil@.*$</packageUrl>
    <cve>CVE-2019-18874</cve>
  </suppress>
  -->

</suppressions>
